# Data — never committed. Fetch with `python -m data.download`.
/data/raw/
/data/processed/
*.csv
*.parquet
*.nc
*.zip

# Model artifacts — regenerate with `python -m services.<module>.train`
/models/**/*.pt
/models/**/*.pkl
/models/**/*.joblib
!/models/**/MODEL_CARD.md

# ...except the ONNX serving artifacts and their model cards, which ARE
# committed. They are small (the fuel map is 363 kB), and the deployed API
# loads them directly: leaving them out means every deployment silently serves
# an untrained model with engine wear assumed healthy. Training inputs stay
# uncommitted; the trained output that production depends on does not.
!/models/**/*.onnx
!/models/**/*.card.json

# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.ruff_cache/
*.egg-info/

# Node
node_modules/
.next/
out/
.turbo/

# Env — never commit keys. Public repo.
.env
.env.local
.env*.local
!.env.example

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Playwright MCP screenshot artifacts
.playwright-mcp/
