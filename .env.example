# Marine-AI environment template.
#
# Copy to `.env` and fill in. `.env` is gitignored; this file is committed and
# must never contain a real secret.
#
#   cp .env.example .env
#
# Every variable below is OPTIONAL. The system runs end-to-end without any of
# them: storage falls back to local SQLite, the advisory layer falls back to
# deterministic templates, and marine forecasts come from a keyless public API.
# Nothing in the demo path blocks on a credential.

# --- Storage ---------------------------------------------------------------
# Supabase Postgres. Get from: Project Settings -> Database -> Connection string
# -> URI. Use the POOLER host (port 6543 for transaction mode, 5432 for session
# mode); the direct db.<ref>.supabase.co host is IPv6-only on the free tier and
# will fail to resolve from most networks.
#
# Unset -> falls back to a local SQLite file at data/marine.db.
DATABASE_URL=

# Public anon key. Safe to expose in a browser; it is protected by row-level
# security. Never put the service_role key in this file or anywhere near the
# frontend: it bypasses RLS entirely, and this repository is public.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Natural-language advisory ---------------------------------------------
# Anthropic API key for the plain-language bridge advisory (English + Filipino).
# Unset -> deterministic templates. The display marks which source was used, so
# a missing key degrades visibly rather than silently.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Marine forecasts ------------------------------------------------------
# Open-Meteo Marine requires no key on the free tier. Override only if you move
# to their commercial endpoint.
OPEN_METEO_MARINE_URL=https://marine-api.open-meteo.com/v1/marine
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast

# --- Local operation -------------------------------------------------------
# Diesel price in PHP per litre. Drives the peso figures on the bridge display
# and the monthly savings report. Update to the operator's actual pump price.
DIESEL_PRICE_PHP_PER_L=68.50

# kg CO2 per litre of marine diesel burned. 2.68 is the widely used factor for
# diesel fuel oil; cite the source in any emissions report you publish.
CO2_KG_PER_L_DIESEL=2.68

# API bind address for local development.
API_HOST=127.0.0.1
API_PORT=8000

# --- Deployment ------------------------------------------------------------
# Where the bridge display finds the advisory API. Baked into the JavaScript
# bundle at BUILD time (that is what NEXT_PUBLIC_ means), so changing it needs a
# redeploy, not just a restart.
#
# MUST be https:// on a deployed site. A page served over HTTPS cannot call an
# http:// endpoint -- browsers block it as mixed content, and the display shows
# "ADVISORY OFFLINE" with no error a judge could diagnose.
#
# Unset -> http://localhost:8000, which is correct for local development and
# fatal in production.
NEXT_PUBLIC_API_URL=

# Origins the API accepts browser requests from, comma separated. Set this to
# the deployed display's origin. Unset -> localhost dev ports only.
MARINE_AI_CORS_ORIGINS=

# Regex for additional allowed origins. Defaults to https://.*\.vercel\.app so
# that preview deployments keep working without pinning each one by hand.
MARINE_AI_CORS_ORIGIN_REGEX=
